<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (HTTP) for local-network testing while keeping
         HTTPS as default.  The trust-all TLS in ApiClient handles
         Cloudflare intermediate cert mismatches on older Android. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
